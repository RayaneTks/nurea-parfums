# Copier vers `.env.local` — ne jamais committer les secrets.

# Resend (https://resend.com) — envoi du formulaire contact
# Domaine d’expéditeur doit être vérifié chez Resend.
RESEND_API_KEY=
RESEND_FROM="Nurea <contact@votredomaine.com>"

# Destinataire des messages (souvent identique à CONTACT.email dans le code)
CONTACT_TO_EMAIL=conciergerie@nureaparfums.com

# Google Search Console (optionnel)
# GOOGLE_SITE_VERIFICATION=

# --- Fraganty (prioritaire si la clé est définie) — https://fraganty.ai/api-docs
# Sans clé en production (ex. Vercel) : aucune suggestion API, seulement hints statiques + mock.
# Clé uniquement serveur. Ne jamais committer.
FRAGANTY_API_KEY=
FRAGANTY_API_BASE_URL=https://fraganty.ai
# Résultats analysés pour le scoring (max 100, défaut 12)
FRAGANTY_API_LIMIT=12

# --- Fallback générique (si FRAGANTY_API_KEY est vide)
# URL absolue. {{query}} ou paramètre ?q= ajouté automatiquement.
PERFUME_EXTERNAL_API_URL=
PERFUME_EXTERNAL_API_KEY=
PERFUME_EXTERNAL_RAPIDAPI_HOST=
# Délai max Fraganty + API générique (défaut 8000 ms, max 30000)
PERFUME_EXTERNAL_API_TIMEOUT_MS=8000
PERFUME_EXTERNAL_SOURCE_LABEL=

# ---------------------------------------------------------------------------
# Catalogue PostgreSQL — optionnel (sans DATABASE_URL → mockPerfumes)
#
# Supabase — Session pooler (recommandé Prisma + Vercel, compatible IPv4) :
#   Utilisateur : postgres.<PROJECT_REF>  (pas seulement "postgres")
#   Hôte : aws-0-...pooler.supabase.com (région affichée dans le dashboard)
#   Port : 5432
#   Toujours ajouter ?sslmode=require
# Exemple :
# DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres?sslmode=require"
#
# Pool transactionnel (port 6543) : ajouter ?pgbouncer=true — utile si la doc Supabase
# vous oriente vers ce mode ; sinon Session pooler 5432 suffit souvent pour Prisma.
#
# Si `prisma migrate` échoue via le pooler, vous pouvez ajouter dans prisma/schema.prisma :
#   directUrl = env("DIRECT_URL")
# puis définir DIRECT_URL vers l’hôte direct db.<ref>.supabase.co (migrations uniquement).
# ---------------------------------------------------------------------------
DATABASE_URL=

# Cache recherche externe (ms). Défauts : positif 7j, négatif 24h, erreur 2min.
SEARCH_CACHE_POSITIVE_TTL_MS=
SEARCH_CACHE_NEGATIVE_TTL_MS=
SEARCH_CACHE_ERROR_TTL_MS=

# ---------------------------------------------------------------------------
# Panel admin (session JWT httpOnly + cookie)
# ADMIN_JWT_SECRET : min. 24 caractères aléatoires (openssl rand -hex 32)
# ---------------------------------------------------------------------------
ADMIN_JWT_SECRET=

# Sondes / intégration : GET /api/admin/health avec Authorization: Bearer …
ADMIN_DASHBOARD_SECRET=

# ---------------------------------------------------------------------------
# Supabase Storage — import d’images depuis le panel admin (serveur uniquement)
# NEXT_PUBLIC_* : exposé au navigateur pour l’URL publique des fichiers + next/image
# SUPABASE_SERVICE_ROLE_KEY : jamais côté client ; uniquement API /api/admin/storage/sign
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Bucket créé dans Storage (défaut du code : catalog)
SUPABASE_STORAGE_BUCKET=catalog

# Créer un compte admin en local :
#   npm run admin:create-user -- mon_identifiant "MotDePasseLong!"

# Playwright : E2E_MOCK_CATALOG_ONLY=1 force le catalogue mock (ignore DATABASE_URL) si la DB est injoignable en local
