# Copier vers `.env.local` — ne jamais committer les secrets.

# Resend (https://resend.com) — envoi du formulaire contact
# Domaine d’expéditeur doit être vérifié chez Resend.
RESEND_API_KEY=
RESEND_FROM="Nurea <contact@votredomaine.com>"

# Destinataire des messages (souvent identique à CONTACT.email dans le code)
CONTACT_TO_EMAIL=conciergerie@nureaparfums.com

# Google Search Console (optionnel)
# GOOGLE_SITE_VERIFICATION=

# Recherche catalogue — fallback API (clé uniquement serveur, jamais exposée au navigateur)
# URL absolue. Utilisez {{query}} pour insérer la requête encodée, sinon un paramètre ?q= est ajouté.
# Réponse JSON attendue : { "results": [ { "externalId": "…", "name": "…", "brand": "…" } ] }
# (tableaux "data", "items" ou "hits" également reconnus)
PERFUME_EXTERNAL_API_URL=
PERFUME_EXTERNAL_API_KEY=
# Si vous passez par RapidAPI : renseigner l’hôte (ex. xxx.p.rapidapi.com) en plus de la clé.
PERFUME_EXTERNAL_RAPIDAPI_HOST=
# Délai max en ms (défaut 8000, plafonné à 30000 côté code)
PERFUME_EXTERNAL_API_TIMEOUT_MS=8000
