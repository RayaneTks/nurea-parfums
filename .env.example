# Copier vers `.env.local` — ne jamais committer les secrets.

# Resend (https://resend.com) — envoi du formulaire contact
# Domaine d’expéditeur doit être vérifié chez Resend.
RESEND_API_KEY=
RESEND_FROM="Nurea <contact@votredomaine.com>"

# Destinataire des messages (souvent identique à CONTACT.email dans le code)
CONTACT_TO_EMAIL=conciergerie@nureaparfums.com

# Google Search Console (optionnel)
# GOOGLE_SITE_VERIFICATION=
