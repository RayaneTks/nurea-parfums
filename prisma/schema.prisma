generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SearchCacheStatus {
  FOUND
  NOT_FOUND
  ERROR
}

enum AdminRole {
  OWNER
  EDITOR
  VIEWER
}

enum ImportSuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  IMPORTED
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  perfumes  Perfume[]
}

model Perfume {
  id         Int               @id
  brandId    String
  brand      Brand             @relation(fields: [brandId], references: [id], onDelete: Restrict)
  name       String
  slug       String            @unique
  category   String
  image      String
  imageLight String?
  imageDark  String?
  status     PublicationStatus @default(PUBLISHED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?

  aliases   PerfumeAlias[]
  tags      PerfumeTag[]
  classics  PerfumeClassic[]
  sizes     PerfumeSize[]
  images    PerfumeImage[]
  notes     PerfumeNote[]

  @@index([category])
  @@index([status])
  @@index([brandId])
}

model PerfumeAlias {
  id         String  @id @default(cuid())
  perfumeId  Int
  perfume    Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  alias      String
  normalized String

  @@index([perfumeId])
  @@index([normalized])
}

model PerfumeTag {
  id        String  @id @default(cuid())
  perfumeId Int
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  tag       String

  @@index([perfumeId])
}

model PerfumeClassic {
  id        String  @id @default(cuid())
  perfumeId Int
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  line      String

  @@index([perfumeId])
}

model PerfumeSize {
  id        String  @id @default(cuid())
  perfumeId Int
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  label     String
  sku       String?
  sortOrder Int     @default(0)

  @@index([perfumeId])
}

model PerfumeImage {
  id        String  @id @default(cuid())
  perfumeId Int
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)
  alt       String?

  @@index([perfumeId])
}

model PerfumeNote {
  id        String  @id @default(cuid())
  perfumeId Int
  perfume   Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)
  layer     String
  label     String

  @@index([perfumeId])
}

model SearchExternalCache {
  id                   String            @id @default(cuid())
  rawQuery             String
  normalizedQuery      String
  categoryKey          String
  status               SearchCacheStatus
  source               String?
  suggestionName       String?
  suggestionBrand      String?
  suggestionExternalId String?
  payload              Json?
  checkedAt            DateTime          @default(now())
  expiresAt            DateTime

  @@unique([normalizedQuery, categoryKey])
  @@index([expiresAt])
}

model AdminUser {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         AdminRole  @default(EDITOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id        String     @id @default(cuid())
  actorId   String?
  actor     AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime   @default(now())

  @@index([createdAt])
}

model ExternalImportSuggestion {
  id           String                 @id @default(cuid())
  externalId   String
  name         String
  brand        String
  source       String?
  payload      Json?
  status       ImportSuggestionStatus @default(PENDING)
  createdAt    DateTime               @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  @@index([status])
}
