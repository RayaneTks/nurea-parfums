generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum BrandCatalogMode {
  CURATED
  COMPLETE
}

enum BrandVisibilityStatus {
  PUBLISHED
  DRAFT
}

enum AdminRole {
  OWNER
  EDITOR
  VIEWER
}

enum OrderStatus {
  PENDING
  READY
  DELIVERED
  CANCELLED
}

model Brand {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  catalogMode BrandCatalogMode @default(CURATED)
  status      BrandVisibilityStatus @default(PUBLISHED)
  image       String?
  imageLight  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  perfumes    Perfume[]
}

model Perfume {
  id         Int               @id @default(autoincrement())
  brandId    String
  brand      Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name       String
  slug       String            @unique
  image      String
  imageLight String?
  isFeatured Boolean           @default(false)
  status     PublicationStatus @default(PUBLISHED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  orderItems OrderItem[]
  saleItems  SaleItem[]

  @@unique([brandId, name])
  @@index([status])
  @@index([brandId])
}

model AdminUser {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  role         AdminRole  @default(EDITOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id        String     @id @default(cuid())
  actorId   String?
  actor     AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime   @default(now())

  @@index([createdAt])
}

model ExternalImportSuggestion {
  id           String    @id @default(cuid())
  externalId   String
  name         String
  brand        String
  source       String?
  payload      Json?
  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
}

// ─── Gestion (compta / ordres / ventes) ────────────────────────────
// Flux 100% manuel : l'admin enregistre ordres et ventes à la main.
// Prix/coûts saisis à chaque ligne, figés en snapshot à la création.

model Order {
  id             String      @id @default(cuid())
  customerName   String?
  orderedAt      DateTime    @default(now())
  deliveryAt     DateTime?
  status         OrderStatus @default(PENDING)
  notes          String?
  /// Acompte encaissé (obligatoire pour passer en READY / « À traiter »)
  depositPaid    Boolean     @default(false)
  /// Montant de l’acompte payé (€), 0 si non payé
  depositAmount  Decimal     @default(0) @db.Decimal(10, 2)
  items          OrderItem[]
  sale           Sale?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status])
  @@index([orderedAt])
  @@index([deliveryAt])
  @@index([depositPaid])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  perfumeId  Int
  quantity   Int      @default(1)
  note       String?
  /// Libellé saisi à la main quand le parfum n’est pas (encore) sur le catalogue (ligne technique).
  manualLabel String?
  /// Flacon 30, 50 ou 100 ml
  volumeMl   Int      @default(100)
  /// Prix unitaire de vente (€) pour ce flacon
  unitPrice  Decimal  @default(0) @db.Decimal(10, 2)
  /// Coût de revient unitaire (€)
  unitCost   Decimal  @default(0) @db.Decimal(10, 2)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  perfume    Perfume  @relation(fields: [perfumeId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([perfumeId])
}

model Sale {
  id           String     @id @default(cuid())
  orderId      String?    @unique
  customerName String?
  soldAt       DateTime   @default(now())
  totalRevenue Decimal    @db.Decimal(10, 2)
  totalCost    Decimal    @db.Decimal(10, 2)
  totalMargin  Decimal    @db.Decimal(10, 2)
  notes        String?
  items        SaleItem[]
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([soldAt])
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  perfumeId       Int?
  perfumeSnapshot Json
  quantity        Int      @default(1)
  volumeMl        Int?
  unitPrice       Decimal  @db.Decimal(10, 2)
  unitCost        Decimal  @db.Decimal(10, 2)
  lineRevenue     Decimal  @db.Decimal(10, 2)
  lineCost        Decimal  @db.Decimal(10, 2)
  lineMargin      Decimal  @db.Decimal(10, 2)
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  perfume         Perfume? @relation(fields: [perfumeId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([perfumeId])
}
