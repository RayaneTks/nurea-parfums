generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum BrandCatalogMode {
  CURATED
  COMPLETE
}

enum BrandVisibilityStatus {
  PUBLISHED
  DRAFT
}

enum AdminRole {
  OWNER
  EDITOR
  VIEWER
}

enum OrderStatus {
  PENDING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentType {
  DEPOSIT
  BALANCE
  REFUND
}

enum BatchStatus {
  OPEN
  CLOSED
}

model Brand {
  id          String                @id @default(cuid())
  name        String                @unique
  slug        String                @unique
  catalogMode BrandCatalogMode      @default(CURATED)
  status      BrandVisibilityStatus @default(PUBLISHED)
  image       String?
  imageLight  String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  perfumes    Perfume[]

  @@index([status])
}

model Perfume {
  id         Int               @id @default(autoincrement())
  brandId    String
  brand      Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name       String
  slug       String            @unique
  image      String
  imageLight String?
  isFeatured Boolean           @default(false)
  /// Parfum privé : utilisable dans commandes/ventes mais exclu du catalogue public.
  isPrivate  Boolean           @default(false)
  status     PublicationStatus @default(PUBLISHED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  orderItems OrderItem[]
  saleItems  SaleItem[]
  pricings   PerfumePricing[]

  @@unique([brandId, name])
  @@index([status])
  @@index([brandId])
  @@index([status, brandId])
  @@index([isPrivate])
}

/// Prix de référence côté serveur. Remplace la `pricingMemory` localStorage.
/// Une ligne par (parfum, volume). Pré-remplit le form commande/vente.
model PerfumePricing {
  perfumeId           Int
  volumeMl            Int
  defaultUnitPriceEur Decimal  @db.Decimal(10, 2)
  defaultUnitCostDzd  Decimal? @db.Decimal(10, 2)
  defaultExchangeRate Decimal? @db.Decimal(8, 4)
  updatedAt           DateTime @updatedAt

  perfume Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@id([perfumeId, volumeMl])
}

model AdminUser {
  id           String               @id @default(cuid())
  username     String               @unique
  passwordHash String
  role         AdminRole            @default(EDITOR)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  auditLogs    AuditLog[]
  payments     PaymentTransaction[]
}

model AuditLog {
  id        String     @id @default(cuid())
  actorId   String?
  actor     AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime   @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}

model ExternalImportSuggestion {
  id           String    @id @default(cuid())
  externalId   String
  name         String
  brand        String
  source       String?
  payload      Json?
  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
}

/// Paramètres globaux (taux de change DZD→EUR par défaut, etc.).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Clients ────────────────────────────────────────────────────
// Source de vérité des acheteurs. Permet historique, ardoise (solde dû),
// KPI clients récurrents, autocomplete dans forms.

model Customer {
  id           String   @id @default(cuid())
  fullName     String
  /// Téléphone normalisé E.164 (ex: +33612345678).
  phoneE164    String?  @unique
  snapchat     String?
  whatsappE164 String?
  address      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
  sales  Sale[]

  @@index([fullName])
}

// ─── Gestion (compta / ordres / ventes) ────────────────────────────
// Flux 100% manuel : l'admin enregistre ordres et ventes à la main.
// Prix/coûts saisis à chaque ligne, figés en snapshot à la création.

model Order {
  id            String               @id @default(cuid())
  /// FK vers Customer (P3). Nullable pour rétro-compat (commandes sans client lié).
  customerId    String?
  customer      Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  /// Dénormalisé : nom du client au moment de la commande (snapshot historique).
  customerName  String?
  /// Contact libre (téléphone, Snapchat, Instagram, …). Optionnel.
  customerContact String?
  orderedAt     DateTime             @default(now())
  deliveryAt    DateTime?
  status        OrderStatus          @default(PENDING)
  notes         String?
  /// CACHE dénormalisé : true si depositPaidTotal > 0. Source de vérité = PaymentTransaction.
  depositPaid   Boolean              @default(false)
  /// CACHE dénormalisé : somme des DEPOSIT moins REFUND (€). Recalculé sur mutation paiement.
  depositAmount Decimal              @default(0) @db.Decimal(10, 2)
  items         OrderItem[]
  sale          Sale?
  payments      PaymentTransaction[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status])
  @@index([orderedAt])
  @@index([deliveryAt])
  @@index([depositPaid])
  @@index([status, deliveryAt])
  @@index([customerId])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  /// Nullable pour parfums hors-catalogue (one-shots). Si null, perfumeSnapshot obligatoire.
  perfumeId       Int?
  quantity        Int      @default(1)
  /// Quantité déjà livrée pour cette ligne (0..quantity). Suivi livraison partielle.
  deliveredQuantity Int    @default(0)
  note            String?
  /// Flacon 30, 50 ou 100 ml
  volumeMl        Int      @default(100)
  /// Prix unitaire de vente (€) pour ce flacon
  unitPrice       Decimal  @default(0) @db.Decimal(10, 2)
  /// Coût de revient unitaire (€) - Calculé via unitCostDzd / exchangeRate
  unitCost        Decimal  @default(0) @db.Decimal(10, 2)
  /// Don : parfum offert (prix 0 autorisé, coût de revient compté en perte).
  isGift          Boolean  @default(false)
  /// Coût d'achat en DZD
  unitCostDzd     Decimal? @db.Decimal(10, 2)
  /// Taux de change (ex: 277)
  exchangeRate    Decimal? @db.Decimal(10, 2)
  /// Snapshot perfume si perfumeId null (off-catalog).
  perfumeSnapshot Json?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  perfume Perfume? @relation(fields: [perfumeId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([perfumeId])
}

/// Historique des paiements liés aux commandes.
/// Source de vérité pour `Order.depositPaid` et `Order.depositAmount` (cache dénormalisé).
/// Types :
///   DEPOSIT — acompte initial. Premier DEPOSIT déclenche PENDING → READY.
///   BALANCE — solde encaissé (après livraison, ou à la livraison).
///   REFUND  — remboursement (montant positif, soustrait du total payé).
model PaymentTransaction {
  id           String      @id @default(cuid())
  orderId      String
  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type         PaymentType
  /// Montant positif (€). Pour REFUND, le sens "sortant" est porté par le type.
  amount       Decimal     @db.Decimal(10, 2)
  paidAt       DateTime    @default(now())
  /// Moyen de paiement libre (cash, virement, snap-pay, ...).
  method       String?
  note         String?
  recordedById String?
  recordedBy   AdminUser?  @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([orderId])
  @@index([paidAt])
  @@index([type])
}

model Sale {
  id           String     @id @default(cuid())
  orderId      String?    @unique
  /// Dénormalisé. Pour ventes directes, peut différer de customer.fullName.
  customerName String?
  /// Contact libre saisi sur le ticket (téléphone, Snapchat, Instagram, …).
  /// Utile pour ventes orphelines sans Customer lié.
  customerContact String?
  /// FK vers Customer (P3). Nullable pour ventes orphelines historiques.
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  /// FK optionnelle vers une commande groupée. Permet d'agréger les ventes
  /// d'un même envoi physique (transport, douane, billet avion à imputer).
  batchId      String?
  batch        Batch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  soldAt       DateTime   @default(now())
  totalRevenue Decimal    @db.Decimal(10, 2)
  totalCost    Decimal    @db.Decimal(10, 2)
  totalMargin  Decimal    @db.Decimal(10, 2)
  /// Solde restant dû sur les ventes livrées partiellement payées (legacy main).
  /// Remplacé fonctionnellement par PaymentTransaction (REFUND/BALANCE) en P6 ;
  /// gardé pour compat schéma DB existante.
  remainingDue Decimal    @default(0) @db.Decimal(10, 2)
  notes        String?
  items        SaleItem[]
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([soldAt])
  @@index([customerId])
  @@index([batchId])
}

/// Commande groupée (batch). Plusieurs ventes appartiennent à un même envoi
/// physique (commande fournisseur, lot mensuel). Permet de suivre la marge
/// réelle après dépenses logistiques (transport, billet d'avion, douane).
model Batch {
  id         String      @id @default(cuid())
  /// Nom libre saisi par l'admin ("Commande de Mars", "Lot 2026-04").
  name       String
  /// Date prévue d'arrivée / livraison (info éditoriale).
  expectedAt DateTime?
  status     BatchStatus @default(OPEN)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  sales    Sale[]
  expenses BatchExpense[]

  @@index([status])
  @@index([createdAt])
}

/// Dépense rattachée à un batch (transport, billet avion, douane, etc.).
/// Soustraite de la marge brute du batch pour donner la marge nette.
model BatchExpense {
  id         String   @id @default(cuid())
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  /// Libellé court ("Billet avion", "Transporteur DHL", ...).
  label      String
  /// Montant en € (toujours positif).
  amount     Decimal  @db.Decimal(10, 2)
  occurredAt DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())

  @@index([batchId])
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  perfumeId       Int?
  perfumeSnapshot Json
  quantity        Int      @default(1)
  volumeMl        Int?
  unitPrice       Decimal  @db.Decimal(10, 2)
  unitCost        Decimal  @db.Decimal(10, 2)
  /// Don : parfum offert (prix 0, coût compté en perte).
  isGift          Boolean  @default(false)
  unitCostDzd     Decimal? @db.Decimal(10, 2)
  exchangeRate    Decimal? @db.Decimal(10, 2)
  lineRevenue     Decimal  @db.Decimal(10, 2)
  lineCost        Decimal  @db.Decimal(10, 2)
  lineMargin      Decimal  @db.Decimal(10, 2)
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  perfume         Perfume? @relation(fields: [perfumeId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([perfumeId])
}

/// Trésorerie — « poche » où se trouve l'argent (espèces, Revolut, avance fournisseur…).
/// Solde = openingBalance + Σ(movements.amount). Une poche système « Non attribué »
/// (isSystem) recueille tout mouvement saisi sans poche, à répartir ensuite.
enum PocketKind {
  CASH
  BANK
  SUPPLIER
  OTHER
  UNASSIGNED
}

model Pocket {
  id             String         @id @default(cuid())
  name           String
  kind           PocketKind     @default(OTHER)
  /// Montant réel à la création (point de départ). 0 par défaut.
  openingBalance Decimal        @default(0) @db.Decimal(10, 2)
  archived       Boolean        @default(false)
  /// true pour la poche système « Non attribué » (non supprimable, unique).
  isSystem       Boolean        @default(false)
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  movements      CashMovement[]

  @@index([archived])
}

enum CashMovementKind {
  OPENING
  SALE_IN
  DEPOSIT_IN
  BALANCE_IN
  REFUND_OUT
  EXPENSE_OUT
  SUPPLIER_OUT
  TRANSFER
  ADJUSTMENT
}

/// Mouvement d'argent affectant une poche. amount signé : + entrée, − sortie.
model CashMovement {
  id              String           @id @default(cuid())
  pocketId        String
  pocket          Pocket           @relation(fields: [pocketId], references: [id], onDelete: Cascade)
  amount          Decimal          @db.Decimal(10, 2)
  kind            CashMovementKind
  occurredAt      DateTime         @default(now())
  label           String?
  /// Lien souple vers l'origine pour réversibilité (Sale, PaymentTransaction, BatchExpense, Manual).
  refType         String?
  refId           String?
  /// Regroupe les 2 lignes d'un transfert entre poches.
  transferGroupId String?
  createdById     String?
  createdAt       DateTime         @default(now())

  @@index([pocketId])
  @@index([refType, refId])
  @@index([transferGroupId])
}
