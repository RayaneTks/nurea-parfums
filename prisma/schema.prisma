generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum BrandCatalogMode {
  CURATED
  COMPLETE
}

enum BrandVisibilityStatus {
  PUBLISHED
  DRAFT
}

enum AdminRole {
  OWNER
  EDITOR
  VIEWER
}

enum CustomerOrderStatus {
  PENDING
  FULFILLED
  CANCELLED
}

model Brand {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  catalogMode BrandCatalogMode @default(CURATED)
  status      BrandVisibilityStatus @default(PUBLISHED)
  image       String?
  imageLight  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  perfumes    Perfume[]
}

model Perfume {
  id         Int               @id @default(autoincrement())
  brandId    String
  brand      Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name       String
  slug       String            @unique
  image      String
  imageLight String?
  isFeatured Boolean           @default(false)
  status     PublicationStatus @default(PUBLISHED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  cashSaleLines CashSaleLine[]

  @@unique([brandId, name])
  @@index([status])
  @@index([brandId])
}

/// Vente enregistrée depuis la caisse (une ou plusieurs lignes parfum).
model CashSale {
  id        String         @id @default(cuid())
  note      String?
  createdAt DateTime       @default(now())
  lines     CashSaleLine[]

  @@index([createdAt])
}

/// Ligne de vente : prix d’achat unitaire, prix de vente unitaire, quantité (marges calculées côté appli).
model CashSaleLine {
  id             String   @id @default(cuid())
  saleId         String
  sale           CashSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  perfumeId      Int
  perfume        Perfume  @relation(fields: [perfumeId], references: [id], onDelete: Restrict)
  buyPriceCents  Int
  sellPriceCents Int
  quantity       Int

  @@index([saleId])
  @@index([perfumeId])
}

/// Commande client (hors vente immédiate).
model CustomerOrder {
  id           String               @id @default(cuid())
  customerName String
  details      String
  status       CustomerOrderStatus  @default(PENDING)
  note         String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([status])
  @@index([createdAt])
}

model AdminUser {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  role         AdminRole  @default(EDITOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id        String     @id @default(cuid())
  actorId   String?
  actor     AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime   @default(now())

  @@index([createdAt])
}

model ExternalImportSuggestion {
  id           String    @id @default(cuid())
  externalId   String
  name         String
  brand        String
  source       String?
  payload      Json?
  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
}
